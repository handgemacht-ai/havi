{
  "manifest_version": 3,
  "name": "Annotation Platform",
  "version": "0.1.0",
  "description": "Self-hosted annotation platform for developer teams",
  "permissions": ["activeTab", "sidePanel", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "assets/fabric.min.js",
        "assets/cropper.min.js",
        "assets/css-selector-generator.min.js",
        "src/content/content.js"
      ],
      "css": [
        "assets/cropper.min.css",
        "src/content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "commands": {
    "toggle-capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "Start annotation capture"
    }
  },
  "action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_title": "Annotation Platform"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
