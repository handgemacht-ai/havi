{
  "manifest_version": 3,
  "name": "HAVI \u2013 Human-Agent Visual Interface",
  "version": "0.1.1",
  "description": "Self-hosted visual annotations on any web page. Bridge human feedback to AI coding agents in real time.",
  "homepage_url": "https://github.com/handgemacht-ai/havi",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "assets/fabric.min.js",
        "assets/cropper.min.js",
        "assets/css-selector-generator.min.js",
        "src/content/content.js"
      ],
      "css": [
        "assets/cropper.min.css",
        "src/content/content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/context-collector.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "commands": {
    "toggle-capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "Start annotation capture"
    }
  },
  "action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_title": "HAVI"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
